# =============================================
# Application
# =============================================
APP_ENV=development
CORS_ORIGIN=http://localhost:5173

# =============================================
# Database (локальный запуск без Docker)
# В Docker значения DB_HOST и DB_PORT
# переопределяются прямо в docker-compose.yml
# =============================================
DB_HOST=localhost
DB_PORT=5433
DB_NAME=AkitaStudio
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# =============================================
# SMS.ru
# =============================================
SMS_API_KEY=your_smsru_api_key_here

# =============================================
# DaData
# =============================================
DADATA_TOKEN=your_dadata_token_here
DADATA_SECRET=your_dadata_secret_here

# =============================================
# MinIO (объектное хранилище)
# В Docker MINIO_ENDPOINT переопределяется на 'minio' (см. docker-compose.yml)
# =============================================
MINIO_ROOT_USER=akita_admin
MINIO_ROOT_PASSWORD=change_me_in_production
# MINIO_ACCESS_KEY и MINIO_SECRET_KEY используются PHP SDK.
# Если не заданы — SDK автоматически использует MINIO_ROOT_USER/MINIO_ROOT_PASSWORD.
# Задайте явно, если используете отдельного MinIO-пользователя.
MINIO_ACCESS_KEY=akita_admin
MINIO_SECRET_KEY=change_me_in_production
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_PUBLIC_URL=http://localhost:9000

# =============================================
# Vue / Vite (префикс VITE_ обязателен)
# =============================================
VITE_API_URL=http://localhost:8000/api

# =============================================
# Администратор (используется командой make init)
# =============================================
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_in_production
